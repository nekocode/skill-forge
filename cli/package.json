{
  "name": "@nekocode/skill-forge",
  "version": "0.8.1",
  "description": "CLI for skill-forge — install plugins, manage skill registry, diagnose environments.",
  "type": "module",
  "bin": {
    "skill-forge": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
