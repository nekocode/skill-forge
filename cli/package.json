    "cli"
  ],
  "author": "nekocode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nekocode/skill-forge"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.0"
  }
}
